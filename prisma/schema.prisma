generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Project {
  id        String        @id @default(dbgenerated("gen_random_uuid()"))
  name      String        @unique
  createdAt DateTime      @default(now())
  meta      Json?
  reports   DailyReport[]
}

model DailyReport {
  id        String   @id @default(uuid())
  projectId String
  date      DateTime
  createdAt DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  issues    Issue[]

  @@index([projectId])
  @@index([date])
}

model Issue {
  id        String      @id @default(uuid())
  reportId  String
  detail    String
  imageUrl  String?
  createdAt DateTime    @default(now())
  report    DailyReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([reportId])
}

/** =========================
 *  Auth (Invite-only)
 *  ========================= */

enum Role {
  USER
  ADMIN
}

model AllowedEmail {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  role      Role     @default(USER)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  role         Role     @default(USER)
  passwordHash String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model PasswordToken {
  id        String   @id @default(cuid())
  userEmail String
  tokenHash String   @unique
  purpose   String   // "reset"
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([userEmail])
  @@index([expiresAt])
}
