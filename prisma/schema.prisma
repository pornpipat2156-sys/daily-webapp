generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Project {
  id        String   @id @default(dbgenerated("gen_random_uuid()"))
  name      String   @unique
  createdAt DateTime @default(now())
  meta      Json?

  reports       DailyReport[]
  projectAdmins ProjectAdmin[]

  chatMembers  ChatGroupMember[]
  chatMessages ChatMessage[]

  weeklyReports  WeeklyReport[]
  monthlyReports MonthlyReport[]

  notifications Notification[]
}

model DailyReport {
  id        String   @id @default(uuid())
  projectId String
  date      DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  payload Json?

  initialPayload    Json?
  initialIssues     Json?
  initialCapturedAt DateTime?

  project   Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  issues    Issue[]
  approvals ReportApproval[] @relation("ReportApprovals")

  @@unique([projectId, date])
  @@index([projectId])
  @@index([date])
}

model Issue {
  id        String   @id @default(uuid())
  reportId  String
  detail    String
  imageUrl  String?
  createdAt DateTime @default(now())

  report   DailyReport    @relation(fields: [reportId], references: [id], onDelete: Cascade)
  comments IssueComment[]

  @@index([reportId])
}

model WeeklyReport {
  id              String   @id @default(cuid())
  projectId       String
  year            Int
  weekNo          Int
  startDate       DateTime
  endDate         DateTime
  title           String?
  summary         String?
  payload         Json?
  sourceReportIds String[] @default([])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @default(now()) @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, year, weekNo])
  @@index([projectId])
  @@index([startDate])
  @@index([endDate])
}

model MonthlyReport {
  id              String   @id @default(cuid())
  projectId       String
  year            Int
  month           Int
  startDate       DateTime
  endDate         DateTime
  title           String?
  summary         String?
  payload         Json?
  sourceReportIds String[] @default([])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @default(now()) @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, year, month])
  @@index([projectId])
  @@index([startDate])
  @@index([endDate])
}

enum Role {
  USER
  ADMIN
  SUPERADMIN
}

model AllowedEmail {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  role      Role     @default(USER)
  position  String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  role         Role     @default(USER)
  passwordHash String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  projectAdminOf  ProjectAdmin[]
  issueComments   IssueComment[]
  reportApprovals ReportApproval[] @relation("UserApprovals")

  chatGroups   ChatGroupMember[]
  chatMessages ChatMessage[]

  pushSubscriptions PushSubscription[]
  pushDeliveryLogs  PushDeliveryLog[]
  notifications     Notification[]
}

model PasswordToken {
  id        String   @id @default(cuid())
  userEmail String
  tokenHash String   @unique
  purpose   String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([userEmail])
  @@index([expiresAt])
}

model IssueComment {
  id        String   @id @default(cuid())
  issueId   String
  authorId  String
  comment   String
  createdAt DateTime @default(now())

  issue  Issue @relation(fields: [issueId], references: [id], onDelete: Cascade)
  author User  @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([issueId])
  @@index([authorId])
}

model ProjectAdmin {
  id        String   @id @default(cuid())
  projectId String
  userId    String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([projectId])
  @@index([userId])
}

model ReportApproval {
  id             String   @id @default(cuid())
  reportId       String
  approverName   String
  approverRole   String?
  approverUserId String?
  approvedAt     DateTime @default(now())
  createdAt      DateTime @default(now())

  report   DailyReport @relation("ReportApprovals", fields: [reportId], references: [id], onDelete: Cascade)
  approver User?       @relation("UserApprovals", fields: [approverUserId], references: [id], onDelete: SetNull)

  @@unique([reportId, approverName])
  @@index([reportId])
  @@index([approverUserId])
}

model ChatGroupMember {
  id        String   @id @default(cuid())
  projectId String
  userId    String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId], name: "projectId_userId")
  @@index([projectId])
  @@index([userId])
}

model ChatMessage {
  id             String   @id @default(cuid())
  projectId      String
  authorId       String
  text           String?
  reportId       String?
  mentionUserIds String[] @default([])
  createdAt      DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  author  User    @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([projectId, createdAt])
  @@index([authorId])
}

model PushSubscription {
  id         String   @id @default(cuid())
  userId     String
  endpoint   String   @unique
  p256dh     String
  auth       String
  userAgent  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt
  lastUsedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

model PushDeliveryLog {
  id        String   @id @default(cuid())
  userId    String
  dedupeKey String
  channel   String
  title     String?
  body      String?
  payload   Json?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, dedupeKey])
  @@index([userId])
  @@index([dedupeKey])
  @@index([createdAt])
}

enum NotificationType {
  MENTION
  APPROVAL
  SYSTEM
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  url       String?
  sourceKey String?
  groupKey  String?
  projectId String?
  readAt    DateTime?
  meta      Json?
  createdAt DateTime         @default(now())

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@unique([userId, sourceKey])
  @@index([userId, readAt, createdAt])
  @@index([type])
  @@index([projectId])
  @@index([groupKey])
}