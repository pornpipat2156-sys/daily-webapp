generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Project {
  id        String        @id @default(dbgenerated("gen_random_uuid()"))
  name      String        @unique
  createdAt DateTime      @default(now())
  meta      Json?
  reports   DailyReport[]

  projectAdmins ProjectAdmin[]
}

model DailyReport {
  id        String   @id @default(uuid())
  projectId String
  date      DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  // ✅ เก็บข้อมูลฟอร์ม Daily-report ทั้งก้อน (แก้ไขได้)
  payload   Json?

  // ✅ เก็บ "ข้อมูลครั้งแรกของวันนั้น" (ห้ามแก้ แม้กลับมาแก้ไขรายงานภายหลัง)
  initialPayload     Json?
  initialIssues      Json?
  initialCapturedAt  DateTime?

  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  issues    Issue[]
  approvals ReportApproval[] @relation("ReportApprovals")

  // ✅ สำคัญมาก: ทำให้ upsert by project+date ได้
  @@unique([projectId, date])

  @@index([projectId])
  @@index([date])
}



model Issue {
  id        String      @id @default(uuid())
  reportId  String
  detail    String
  imageUrl  String?
  createdAt DateTime    @default(now())
  report    DailyReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  comments IssueComment[]

  @@index([reportId])
}

/**
 * =========================
 * Auth (Invite-only)
 * =========================
 */

enum Role {
  USER
  ADMIN
  SUPERADMIN
}

model AllowedEmail {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  role      Role     @default(USER)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  role         Role     @default(USER)
  passwordHash String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  projectAdminOf ProjectAdmin[]
  issueComments  IssueComment[]
  reportApprovals ReportApproval[] @relation("UserApprovals")

}

model PasswordToken {
  id        String    @id @default(cuid())
  userEmail String
  tokenHash String    @unique
  purpose   String // "reset"
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userEmail])
  @@index([expiresAt])
}

model IssueComment {
  id        String   @id @default(cuid())
  issueId   String
  authorId  String
  comment   String
  createdAt DateTime @default(now())

  issue  Issue @relation(fields: [issueId], references: [id], onDelete: Cascade)
  author User  @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([issueId])
  @@index([authorId])
}

model ProjectAdmin {
  id        String   @id @default(cuid())
  projectId String
  userId    String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([projectId])
  @@index([userId])
}

model ReportApproval {
  id            String    @id @default(cuid())
  reportId       String
  approverName   String
  approverRole   String?
  approverUserId String?
  approvedAt     DateTime  @default(now())
  createdAt      DateTime  @default(now())

  report   DailyReport @relation("ReportApprovals", fields: [reportId], references: [id], onDelete: Cascade)
  approver User?       @relation("UserApprovals", fields: [approverUserId], references: [id], onDelete: SetNull)

  @@unique([reportId, approverName])
  @@index([reportId])
  @@index([approverUserId])
}
